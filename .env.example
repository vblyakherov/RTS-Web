# PostgreSQL
POSTGRES_DB=tracker
POSTGRES_USER=tracker_user
POSTGRES_PASSWORD=change_me_strong_password

# App
DATABASE_URL=postgresql+asyncpg://tracker_user:change_me_strong_password@db:5432/tracker
SECRET_KEY=change_me_very_long_random_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
EXCEL_EXPORT_TOKEN_EXPIRE_MINUTES=10080

# App settings
APP_ENV=production
ALLOWED_ORIGINS=http://localhost,http://your-domain.com
