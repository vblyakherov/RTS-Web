# PostgreSQL
POSTGRES_DB=tracker
POSTGRES_USER=tracker_user
POSTGRES_PASSWORD=change_me_strong_password

# App
DATABASE_URL=postgresql+asyncpg://tracker_user:change_me_strong_password@db:5432/tracker
SECRET_KEY=change_me_very_long_random_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
EXCEL_EXPORT_TOKEN_EXPIRE_MINUTES=10080

# App settings
APP_ENV=production
ALLOWED_ORIGINS=http://localhost,http://your-domain.com

# Auth: local or ldap
AUTH_BACKEND=local

# LDAP / Active Directory
LDAP_SERVER_URL=ldaps://rtk-service.ru:636
LDAP_BIND_DN=CN=tracker-bind,OU=Service Accounts,DC=rtk-service,DC=ru
LDAP_BIND_PASSWORD=change_me_ldap_bind_password
LDAP_USER_BASE_DN=DC=rtk-service,DC=ru
LDAP_USER_FILTER=(&(objectClass=user)(sAMAccountName={username}))
# Optional, used when there is no service bind account or when AD requires UPN bind.
# Example: {username}@rtk-service.ru
LDAP_USER_DN_TEMPLATE=
LDAP_USERNAME_ATTRIBUTE=sAMAccountName
LDAP_FULL_NAME_ATTRIBUTE=displayName
LDAP_EMAIL_ATTRIBUTE=mail
LDAP_GROUP_ATTRIBUTE=memberOf
LDAP_USERS_GROUP=tracker_users
LDAP_ADMINS_GROUP=tracker_admins
LDAP_DEFAULT_EMAIL_DOMAIN=rtk-service.ru
LDAP_CONNECT_TIMEOUT=5
